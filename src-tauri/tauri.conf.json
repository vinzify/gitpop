{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPop",
  "version": "1.4.1",
  "identifier": "com.vinzify.gitpop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVENjAyQjMyNzkxOUY0ODgKUldTSTlCbDVNaXRnWGIxcmtKemlUN3d4RkZRZEpZUkg1aWFaRkRNRGJ3TUZKTlFSbFRFWEYwZi8K",
      "endpoints": [
        "https://github.com/vinzify/gitpop/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "GitPop",
        "width": 450,
        "height": 650,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}